# Railway: no painel do serviço (Variables), defina DATABASE_URL e JWT_SECRET neste mesmo
# serviço que roda o uvicorn. Se usar o plugin Postgres da Railway, use "Add variable reference"
# para copiar DATABASE_URL do banco para o serviço web — o deploy não lê arquivo .env do repo.

# Neon: pode colar postgresql://, postgres://, +psycopg2 ou +asyncpg — o app normaliza
# (runtime FastAPI usa asyncpg; Alembic usa psycopg2)
# sslmode=require, channel_binding=require, etc.: removidos da query para asyncpg; TLS via connect_args quando preciso
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=change-me-min-32-chars-recommended
ENCRYPTION_KEY=change-me-32-bytes-pad-with-zeros-like-ts

# Origens CORS separadas por vírgula (dev: Vite em :5173).
# Produção: inclua a URL exata do frontend na Netlify, ex.:
#   https://seu-app.netlify.app
# Domínio customizado: use https://chat.seudominio.com (sem barra final).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL pública da API (Railway). Alinhe com o domínio gerado pelo Railway ou custom domain.
API_PUBLIC_BASE_URL=https://sua-api.up.railway.app
